// ═══════════════════════════════════════════════════════════════════════════════

/**
 * Send a plain text message.
 * @param {string} phone
 * @param {string} text
 */
async function sendMessage(phone, text) {
  return _wrap("sendMessage", () => sendTextMessage(phone, text), "WHATSAPP_SEND_FAILED");
}

