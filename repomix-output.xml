      : Promise.resolve({ task: "low_stock_alert", status: "skipped" });
    const [lsFireResult] = await Promise.allSettled([lowStockTaskFires]);
    assert(lsFireResult.value.status === "ok", "Low-stock alert fires when stock ≤ threshold");

