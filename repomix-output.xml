  // Individual Handlers (exported for direct controller use)
  handleGreeting,
  handleBrowseCatalog,
  handleSearchProduct,
  handleSizeHelp,
  handleViewCart,
  handlePaymentQuery,
  handleOrderStatus,
  handleReturnExchange,
  handleFarewell,
  handleUnknown,
  handleImageSearchPrompt,
};


